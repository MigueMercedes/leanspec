  "description": "Pragmatic Spec-Driven Development framework for Claude Code — npm CLI that scaffolds the full SDD pipeline (specs, prompts, skill, ADR/runbook conventions) into any project",
  "type": "module",
  "bin": {
    "claude-sdd": "./bin/cli.js"
  },
  "files": [
