  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MigueMercedes/claude-sdd.git"
  },
  "homepage": "https://github.com/MigueMercedes/claude-sdd#readme",
  "bugs": {
    "url": "https://github.com/MigueMercedes/claude-sdd/issues"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "kleur": "^4.1.5",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "vitest": "^2.1.0"
  }
}
